      "u8:15"
    ]
  },
  {
    "op": "6B",
    "offset": 2,
    "args": [
      "u8:15"
    ]
  },
  {
    "op": "15",
    "offset": 4,
    "args": [
      "\u0001\u0002「今夜の月は綺麗ね」\u0001"
    ]
  },
  {
    "op": "6B",
    "offset": 29,
    "args": [
      "u8:35"
    ]
  },
  {
    "op": "15",
    "offset": 31,
    "args": [
      "\u0001隣でひっそりと囁く声が聞こえた。\u0001"
    ]
  },
  {
    "op": "6B",
    "offset": 67,
    "args": [
      "u8:45"
    ]
  },
  {
    "op": "15",
    "offset": 69,
    "args": [
      "\u0001\u0002「そうだな」\u0001"
    ]
  },
  {
    "op": "6B",
    "offset": 86,
    "args": [
      "u8:35"
    ]
  },
  {
    "op": "54",
    "offset": 88,
    "args": [
      "u8:8",
      "se10"
    ]
  },
  {
    "op": "2C",
    "offset": 95,
    "args": [
      "u16:288"
    ]
  },
  {
    "op": "15",
    "offset": 98,
    "args": [
      "\u0001\u0002俺は脚を留めて天空に架かる銀盆を見つめながら言った。\u0001"
    ]
  },
  {
    "op": "6B",
    "offset": 155,
    "args": [
      "u8:45"
    ]
  },
  {
    "op": "15",
    "offset": 157,
    "args": [
      "\u0001\u0002……いったい、何度あの月を見ただろう？\u0001"
    ]
  },
  {
    "op": "6B",
    "offset": 200,
    "args": [
      "u8:40"
    ]
  },
  {
    "op": "15",
    "offset": 202,
    "args": [
      "\u0001そして、これからどれだけ眺め続けるんだろうか？\u0001"
    ]
  },
  {
    "op": "6B",
    "offset": 252,
    "args": [
      "u8:50"
    ]
  },
  {
    "op": "15",
    "offset": 254,
    "args": [
      "\u0001\u0002あれから……俺が夜の住人になってから、数え切れない程の月日が流れた。\u0001"
    ]
  },
  {
    "op": "6B",
    "offset": 327,
    "args": [
      "u8:40"
    ]
  },
  {
    "op": "15",
    "offset": 329,
    "args": [
      "\u0001そしてその間、時を変え、場所を変え、何度あの眩しい輝きを眺めただろう？\u0001"
    ]
  },
  {
    "op": "6B",
    "offset": 403,
    "args": [
      "u8:50"
    ]
  },
  {
    "op": "15",
    "offset": 405,
    "args": [
      "\u0001\u0002「どうしたの？」\u0001"
    ]
  },
  {
    "op": "6B",
    "offset": 426,
    "args": [
      "u8:35"
    ]
  },
  {
    "op": "15",
    "offset": 428,
    "args": [
      "\u0001\u0002「いや、少し感傷的になってただけさ」\u0001"
    ]
  },
  {
    "op": "6B",
    "offset": 469,
    "args": [
      "u8:40"
    ]
  },
  {
    "op": "15",
    "offset": 471,
    "args": [
      "\u0001俺がそう言うと、白い吐息が後を追うように流れた。\u0001"
    ]
  },
  {
    "op": "6B",
    "offset": 523,
    "args": [
      "u8:45"
    ]
  },
  {
    "op": "15",
    "offset": 525,
    "args": [
      "\u0001\u0002彼女は月を眺めながらしばらく間を置き、\u0001"
    ]
  },
  {
    "op": "6B",
    "offset": 568,
    "args": [
      "u8:35"
    ]
  },
  {
    "op": "15",
    "offset": 570,
    "args": [
      "\u0001「……疲れた？」\u0001"
    ]
  },
  {
    "op": "6B",
    "offset": 590,
    "args": [
      "u8:35"
    ]
  },
  {
    "op": "15",
    "offset": 592,
    "args": [
      "\u0001そう訊いてきた。そう言った彼女の声にも拭い去れない疲れが混ざっていた。\u0001"
    ]
  },
  {
    "op": "6B",
    "offset": 666,
    "args": [
      "u8:50"
    ]
  },
  {
    "op": "15",
    "offset": 668,
    "args": [
      "\u0001\u0002「少し……ね。でも死にたくなる程でもない」\u0001"
    ]
  },
  {
    "op": "6B",
    "offset": 715,
    "args": [
      "u8:45"
    ]
  },
  {
    "op": "15",
    "offset": 717,
    "args": [
      "\u0001\u0002「そう」\u0001"
    ]
  },
  {
    "op": "6B",
    "offset": 730,
    "args": [
      "u8:35"
    ]
  },
  {
    "op": "15",
    "offset": 732,
    "args": [
      "\u0001\u0002「シェリは？」\u0001"
    ]
  },
  {
    "op": "6B",
    "offset": 751,
    "args": [
      "u8:35"
    ]
  },
  {
    "op": "15",
    "offset": 753,
    "args": [
      "\u0001\u0002「わたしは……正直よく分からないわ」\u0001"
    ]
  },
  {
    "op": "6B",
    "offset": 794,
    "args": [
      "u8:45"
    ]
  },
  {
    "op": "15",
    "offset": 796,
    "args": [
      "\u0001シェリは曖昧な表情を浮かべて俺の目を見た。\u0001"
    ]
  },
  {
    "op": "6B",
    "offset": 842,
    "args": [
      "u8:45"
    ]
  },
  {
    "op": "15",
    "offset": 844,
    "args": [
      "\u0001その瞳は、俺が初めて見た時と同様に美しかった。\u0001"
    ]
  },
  {
    "op": "6B",
    "offset": 894,
    "args": [
      "u8:45"
    ]
  },
  {
    "op": "15",
    "offset": 896,
    "args": [
      "\u0001\u0002「そっか。…じゃあもう少し生きてみようか？何か良い事があるかも知れない」\u0001"
    ]
  },
  {
    "op": "6B",
    "offset": 973,
    "args": [
      "u8:50"
    ]
  },
  {
    "op": "15",
    "offset": 975,
    "args": [
      "\u0001\u0002「そうね」\u0001"
    ]
  },
  {
    "op": "6B",
    "offset": 990,
    "args": [
      "u8:35"
    ]
  },
  {
    "op": "15",
    "offset": 992,
    "args": [
      "\u0001\u0002彼女は俺の腕に自分の腕を絡め、二人は寄り添うように歩き出した。\u0001"
    ]
  },
  {
    "op": "6B",
    "offset": 1059,
    "args": [
      "u8:45"
    ]
  },
  {
    "op": "15",
    "offset": 1061,
    "args": [
      "\u0001\u0002煌々と輝く蒼い月の下を。\u0001"
    ]
  },
  {
    "op": "6B",
    "offset": 1090,
    "args": [
      "u8:50"
    ]
  },
