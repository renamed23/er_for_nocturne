    ]
  },
  {
    "op": "15",
    "offset": 8490,
    "args": [
      "\u0001\u0002ルミ「…うん……そうだね」\u0001裕也『ダイジョーブ。全然オッケー！ルミちゃんに譲るよ』\u0005"
    ]
  },
  {
    "op": "15",
    "offset": 8576,
    "args": [
      "\u0001\u0002智秋「じゃ…どうすればいいか分かるだろう？」\u0005"
    ]
