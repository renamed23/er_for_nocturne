    ]
  },
  {
    "op": "15",
    "offset": 12912,
    "args": [
      "\u0001\u0002智秋「………」\u0005"
    ]
  },
  {
    "op": "15",
    "offset": 12931,
    "args": [
      "\u0001\u0002少し間を空けて、\u0005\u0001ルミ「……おにいちゃん」\u0005\u0001かすれた声。\u0005"
    ]
  },
  {
    "op": "15",
    "offset": 12992,
    "args": [
      "\u0001\u0002智秋「なに？」\u0005"
    ]
  },
