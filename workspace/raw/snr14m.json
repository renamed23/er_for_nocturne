      "u8:30"
    ]
  },
  {
    "op": "15",
    "offset": 61,
    "args": [
      "\u0001\u0001今日、街で出会った女性。"
    ]
  },
  {
    "op": "6B",
    "offset": 89,
    "args": [
      "u8:30"
    ]
  },
  {
    "op": "15",
    "offset": 91,
    "args": [
      "\u0001\u0001いや、女の姿をした"
    ]
  },
  {
    "op": "6B",
    "offset": 113,
    "args": [
      "u8:10"
    ]
  },
  {
    "op": "15",
    "offset": 115,
    "args": [
      "\u0001……〝何か〟。"
    ]
  },
  {
    "op": "6B",
    "offset": 132,
    "args": [
      "u8:40"
    ]
  },
  {
    "op": "15",
    "offset": 134,
    "args": [
      "\u0001\u0002……あの眼差し。"
    ]
  },
  {
    "op": "6B",
    "offset": 154,
    "args": [
      "u8:30"
    ]
  },
  {
    "op": "15",
    "offset": 156,
    "args": [
      "\u0001\u0001何がどう変わるという確信があったわけではない。"
    ]
  },
  {
    "op": "6B",
    "offset": 206,
    "args": [
      "u8:40"
    ]
  },
  {
    "op": "15",
    "offset": 208,
    "args": [
      "\u0001\u0001漠然とした何か……"
    ]
  },
  {
    "op": "6B",
    "offset": 230,
    "args": [
      "u8:20"
    ]
  },
  {
    "op": "15",
    "offset": 232,
    "args": [
      "\u0001形にならない、ぼんやりとした不安。"
    ]
  },
  {
    "op": "6B",
    "offset": 269,
    "args": [
      "u8:40"
    ]
  },
  {
    "op": "15",
    "offset": 271,
    "args": [
      "\u0001\u0002ひとつだけはっきりしている。"
    ]
  },
  {
    "op": "6B",
    "offset": 303,
    "args": [
      "u8:20"
    ]
  },
  {
    "op": "15",
    "offset": 305,
    "args": [
      "\u0001\u0002あの女をきっかけにして、"
    ]
  },
  {
    "op": "6B",
    "offset": 333,
    "args": [
      "u8:25"
    ]
  },
  {
    "op": "15",
    "offset": 335,
    "args": [
      "\u0001運命という名の歯車が、"
    ]
  },
  {
    "op": "6B",
    "offset": 360,
    "args": [
      "u8:8"
    ]
  },
  {
    "op": "15",
    "offset": 362,
    "args": [
      "\u0001\u0001カチリという音を立てて回りだしたということ。"
    ]
  },
  {
    "op": "6B",
    "offset": 410,
    "args": [
      "u8:40"
    ]
  },
  {
    "op": "15",
    "offset": 412,
    "args": [
      "\u0001\u0002そして刻は戻らない。"
    ]
  },
  {
    "op": "6B",
    "offset": 436,
    "args": [
      "u8:30"
    ]
  },
  {
    "op": "15",
    "offset": 438,
    "args": [
      "\u0001……壊れた物が元には戻らないように。"
    ]
  },
  {
    "op": "6B",
    "offset": 477,
    "args": [
      "u8:40"
    ]
  },
  {
    "op": "21",
