    ]
  },
  {
    "op": "15",
    "offset": 15581,
    "args": [
      "\u0001\u0002ルミ「うん。わたしの事じゃないの…」\u0005"
    ]
  },
  {
    "op": "15",
    "offset": 15622,
    "args": [
      "\u0001\u0002智秋「………」\u0005"
    ]
  },
  {
    "op": "15",
    "offset": 15641,
    "args": [
      "\u0001\u0002ルミ「………」\u0005"
    ]
  },
  {
    "op": "15",
    "offset": 15660,
    "args": [
      "\u0001\u0002智秋「ルミの事じゃない……\u0005ってことは…〝俺の事〟…！？」\u0005\u0001言ってはみたものの、全く見当が付かない。\u0005"
    ]
  },
  {
    "op": "15",
    "offset": 15764,
    "args": [
