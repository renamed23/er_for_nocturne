      "\u0001\u0002ルミ「うん…」\u0005\u0001そう答えたものの、彼女の返事は歯切れが悪い。\u0005"
    ]
  },
  {
    "op": "15",
    "offset": 15448,
    "args": [
      "\u0001\u0002智秋「…そっか。\u0005じゃあまた何かあったら…」\u0005"
    ]
  },
  {
    "op": "55",
    "offset": 15496,
    "args": [
      "u8:8",
      "cgru0200"
    ]
  },
  {
    "op": "15",
    "offset": 15507,
    "args": [
      "\u0001\u0002ルミ「違うの！」\u0005\u0001ルミが意を決したように遮った。\u0005"
    ]
  },
  {
    "op": "15",
    "offset": 15560,
    "args": [
