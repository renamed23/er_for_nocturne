    "args": [
      "\u0001\u0002ルミ「おに～ちゃ～～～ん！！」\u0005\u0001ルミの悲鳴だ！\u0005"
    ]
  },
  {
    "op": "15",
    "offset": 1775,
    "args": [
      "\u0001\u0002がばっ。\u0005\u0001だんだんだんだんだん！\u0005\u0001ベッドから飛び降り、転がるようにキッチンに向かう。\u0005"
    ]
  },
