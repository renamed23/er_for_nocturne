  },
  {
    "op": "15",
    "offset": 12,
    "args": [
      "\u0001\u0002〝俺はどこにいるのか？〟"
    ]
  },
  {
    "op": "6B",
    "offset": 40,
    "args": [
      "u8:30"
    ]
  },
  {
    "op": "15",
    "offset": 42,
    "args": [
      "\u0001\u0002真っ暗な道。"
    ]
  },
  {
    "op": "6B",
    "offset": 58,
    "args": [
      "u8:20"
    ]
  },
  {
    "op": "15",
    "offset": 60,
    "args": [
      "\u0001見通すことさえ出来ない漆黒の闇の中。\u0001"
    ]
  },
  {
    "op": "6B",
    "offset": 100,
    "args": [
      "u8:25"
    ]
  },
  {
    "op": "15",
    "offset": 102,
    "args": [
      "\u0001どこに向かっているかも分からない。"
    ]
  },
  {
    "op": "6B",
    "offset": 139,
    "args": [
      "u8:35"
    ]
  },
  {
    "op": "15",
    "offset": 141,
    "args": [
      "\u0001\u0002進んでるのか、"
    ]
  },
  {
    "op": "6B",
    "offset": 159,
    "args": [
      "u8:7"
    ]
  },
  {
    "op": "15",
    "offset": 161,
    "args": [
      "\u0001戻ってるのか、"
    ]
  },
  {
    "op": "6B",
    "offset": 178,
    "args": [
      "u8:12"
    ]
  },
  {
    "op": "15",
    "offset": 180,
    "args": [
      "\u0001上ってるのか、"
    ]
  },
  {
    "op": "6B",
    "offset": 197,
    "args": [
      "u8:7"
    ]
  },
  {
    "op": "15",
    "offset": 199,
    "args": [
      "\u0001\u0001下りてるのか…"
    ]
  },
  {
    "op": "6B",
    "offset": 217,
    "args": [
      "u8:20"
    ]
  },
  {
    "op": "15",
    "offset": 219,
    "args": [
      "\u0001…そんな事すらも認識できない。"
    ]
  },
  {
    "op": "6B",
    "offset": 252,
    "args": [
      "u8:40"
    ]
  },
  {
    "op": "15",
    "offset": 254,
    "args": [
      "\u0001\u0002そんな場所。"
    ]
  },
  {
    "op": "6B",
    "offset": 270,
    "args": [
      "u8:35"
    ]
  },
  {
    "op": "15",
    "offset": 272,
    "args": [
      "\u0001\u0002〝何をしてるのか？〟"
    ]
  },
  {
    "op": "6B",
    "offset": 296,
    "args": [
      "u8:25"
    ]
  },
  {
    "op": "15",
    "offset": 298,
    "args": [
      "\u0001\u0002走っていた。"
    ]
  },
  {
    "op": "6B",
    "offset": 314,
    "args": [
      "u8:20"
    ]
  },
  {
    "op": "15",
    "offset": 316,
    "args": [
      "\u0001\u0001ただひたすら走っていた。"
    ]
  },
  {
    "op": "6B",
    "offset": 344,
    "args": [
      "u8:25"
    ]
  },
  {
    "op": "15",
    "offset": 346,
    "args": [
      "\u0001\u0001呼吸することも忘れ、"
    ]
  },
  {
    "op": "6B",
    "offset": 370,
    "args": [
      "u8:8"
    ]
  },
  {
    "op": "15",
    "offset": 372,
    "args": [
      "\u0001ただ全力で走っていた。"
    ]
  },
  {
    "op": "6B",
    "offset": 397,
    "args": [
      "u8:30"
    ]
  },
  {
    "op": "15",
    "offset": 399,
    "args": [
      "\u0001\u0002脚の皮が破けても、"
    ]
  },
  {
    "op": "6B",
    "offset": 421,
    "args": [
      "u8:6"
    ]
  },
  {
    "op": "15",
    "offset": 423,
    "args": [
      "\u0001脚がもつれて転んでも、"
    ]
  },
  {
    "op": "6B",
    "offset": 448,
    "args": [
      "u8:6"
    ]
  },
  {
    "op": "15",
    "offset": 450,
    "args": [
      "\u0001疲労が全身を蝕\u0001んでも、"
    ]
  },
  {
    "op": "6B",
    "offset": 476,
    "args": [
      "u8:20"
    ]
  },
  {
    "op": "15",
    "offset": 478,
    "args": [
      "\u0001……それでも俺は走っていた。"
    ]
  },
  {
    "op": "6B",
    "offset": 509,
    "args": [
      "u8:25"
    ]
  },
  {
    "op": "15",
    "offset": 511,
    "args": [
      "\u0001\u0002ただ走った。"
    ]
  },
  {
    "op": "6B",
    "offset": 527,
    "args": [
      "u8:18"
    ]
  },
  {
    "op": "15",
    "offset": 529,
    "args": [
      "\u0001\u0002〝何のために？〟"
    ]
  },
  {
    "op": "6B",
    "offset": 549,
    "args": [
      "u8:20"
    ]
  },
  {
    "op": "15",
    "offset": 551,
    "args": [
      "\u0001\u0002逃げるために。"
    ]
  },
  {
    "op": "6B",
    "offset": 569,
    "args": [
      "u8:18"
    ]
  },
  {
    "op": "15",
    "offset": 571,
    "args": [
      "\u0001恐怖から逃れるために。"
    ]
  },
  {
    "op": "6B",
    "offset": 596,
    "args": [
      "u8:20"
    ]
  },
  {
    "op": "15",
    "offset": 598,
    "args": [
      "\u0001\u0001恐怖を与えるものから遠ざかるために。"
    ]
  },
  {
    "op": "6B",
    "offset": 638,
    "args": [
      "u8:18"
    ]
  },
  {
    "op": "15",
    "offset": 640,
    "args": [
      "\u0001\u0002少しでも遠ざかって、"
    ]
  },
  {
    "op": "6B",
    "offset": 664,
    "args": [
      "u8:6"
    ]
  },
  {
    "op": "15",
    "offset": 666,
    "args": [
      "\u0001少しでも忘れたかった。\u0001"
    ]
  },
  {
    "op": "6B",
    "offset": 692,
    "args": [
      "u8:16"
    ]
  },
  {
    "op": "15",
    "offset": 694,
    "args": [
      "\u0001その為に俺は逃げた。\u0001"
    ]
  },
  {
    "op": "6B",
    "offset": 718,
    "args": [
      "u8:15"
    ]
  },
  {
    "op": "15",
    "offset": 720,
    "args": [
      "\u0001必死で逃げた。\u0001"
    ]
  },
  {
    "op": "6B",
    "offset": 738,
    "args": [
      "u8:20"
    ]
  },
  {
    "op": "15",
    "offset": 740,
    "args": [
      "\u0001\u0002〝何から逃げる？〟"
    ]
  },
  {
    "op": "6B",
    "offset": 762,
    "args": [
      "u8:19"
    ]
  },
  {
    "op": "15",
    "offset": 764,
    "args": [
      "\u0001\u0002…何から…"
    ]
  },
  {
    "op": "6B",
    "offset": 778,
    "args": [
      "u8:4"
    ]
  },
  {
    "op": "15",
    "offset": 780,
    "args": [
      "\u0001…逃げる。\u0001"
    ]
  },
  {
    "op": "6B",
    "offset": 794,
    "args": [
      "u8:24"
    ]
  },
  {
    "op": "15",
    "offset": 796,
    "args": [
      "\u0001\u0002恐怖から……"
    ]
  },
  {
    "op": "6B",
    "offset": 812,
    "args": [
      "u8:5"
    ]
  },
  {
    "op": "15",
    "offset": 814,
    "args": [
      "\u0001認めたくないものから逃げる。"
    ]
  },
  {
    "op": "6B",
    "offset": 845,
    "args": [
      "u8:20"
    ]
  },
  {
    "op": "15",
    "offset": 847,
    "args": [
      "\u0001\u0002忌まわしい運命から、"
    ]
  },
  {
    "op": "6B",
    "offset": 871,
    "args": [
      "u8:4"
    ]
  },
  {
    "op": "15",
    "offset": 873,
    "args": [
      "\u0001残酷な現実から……。\u0001"
    ]
  },
  {
    "op": "6B",
    "offset": 897,
    "args": [
      "u8:12"
    ]
  },
  {
    "op": "21",
    "offset": 899,
    "args": []
  },
  {
    "op": "15",
    "offset": 900,
    "args": [
      "\u0001\u0002……現実。\u0001"
    ]
  },
  {
    "op": "6B",
    "offset": 915,
    "args": [
      "u8:12"
    ]
  },
  {
    "op": "15",
    "offset": 917,
    "args": [
      "\u0001現実って？\u0001"
    ]
  },
  {
    "op": "6B",
    "offset": 931,
    "args": [
      "u8:14"
    ]
  },
  {
    "op": "15",
    "offset": 933,
    "args": [
      "\u0001…ゲンジツって？\u0001"
    ]
  },
  {
    "op": "6B",
    "offset": 953,
    "args": [
      "u8:16"
    ]
  },
  {
    "op": "15",
    "offset": 955,
    "args": [
      "\u0001\u0002それは…"
    ]
  },
  {
    "op": "6B",
    "offset": 967,
    "args": [
      "u8:9"
    ]
  },
  {
    "op": "15",
    "offset": 969,
    "args": [
      "\u0001それは……。"
    ]
  },
  {
    "op": "6B",
    "offset": 984,
    "args": [
      "u8:14"
    ]
  },
  {
    "op": "15",
    "offset": 986,
    "args": [
      "\u0001\u0002人影。"
    ]
  },
  {
    "op": "6B",
    "offset": 996,
    "args": [
      "u8:10"
    ]
  },
  {
    "op": "15",
    "offset": 998,
    "args": [
      "\u0001遠くに人影が見えた。\u0001"
    ]
  },
  {
    "op": "6B",
    "offset": 1022,
    "args": [
      "u8:14"
    ]
  },
  {
    "op": "15",
    "offset": 1024,
    "args": [
      "\u0001俺は夢中でそれに向かって走る。\u0001"
    ]
  },
  {
    "op": "6B",
    "offset": 1058,
    "args": [
      "u8:18"
    ]
  },
  {
    "op": "15",
    "offset": 1060,
    "args": [
