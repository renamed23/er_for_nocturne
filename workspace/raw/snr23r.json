    ]
  },
  {
    "op": "6B",
    "offset": 1087,
    "args": [
      "u8:10"
    ]
  },
  {
    "op": "15",
    "offset": 1089,
    "args": [
      "\u0001\u0002「助けてくれ！」\u0001"
    ]
  },
  {
    "op": "6B",
    "offset": 1110,
    "args": [
      "u8:10"
    ]
  },
  {
    "op": "15",
    "offset": 1112,
    "args": [
