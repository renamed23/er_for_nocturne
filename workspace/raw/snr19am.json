    ]
  },
  {
    "op": "15",
    "offset": 1201,
    "args": [
      "\u0001\u0002アイシャ「時間……ある？」\u0005\u0001視線が横顔にあたるのを感じた。\u0005"
    ]
  },
  {
    "op": "15",
    "offset": 1264,
    "args": [
      "\u0001\u0002智秋「……ああ」\u0005\u0001俺は遠くを見つめながら、自分の声をぼんやりと聴いた。\u0005"
    ]
  },
  {
    "op": "15",
    "offset": 1339,
    "args": [
      "\u0001\u0002アイシャ「前の場所で良いかしら？」\u0005"
    ]
  },
  {
    "op": "15",
    "offset": 1378,
    "args": [
      "\u0001\u0002智秋「………」\u0005"
    ]
  },
  {
    "op": "15",
    "offset": 1397,
    "args": [
      "\u0001\u0002アイシャ「行きましょ」\u0005\u0001彼女が先に歩き出し、その後に俺も続いた。\u0005"
    ]
  },
